{
  "rewrites": [
    { "source": "/s/:slug/sitemap.xml", "destination": "/api/site-public?slug=:slug&page=sitemap-xml" },
    { "source": "/s/:slug/:page", "destination": "/api/site-public?slug=:slug&page=:page" },
    { "source": "/s/:slug", "destination": "/api/site-public?slug=:slug" }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
